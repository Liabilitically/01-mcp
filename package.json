{
  "name": "mcp-convex-bridge",
  "version": "1.0.0",
  "description": "MCP Bridge for Convex backend with SSE transport",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test:http": "node --import dotenv/config scripts/test-mcp-http.mjs"
  },
  "keywords": [
    "mcp",
    "convex",
    "sse",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "convex": "^1.16.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
